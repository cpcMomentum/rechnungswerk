{
  "name": "cpcmomentum/rechnungswerk",
  "description": "Rechnungen und E-Rechnungen schreiben mit automatischer DATEV-Übergabe",
  "license": "AGPL-3.0-or-later",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "ext-gd": "*",
    "ext-mbstring": "*",
    "bacon/bacon-qr-code": "^3.0",
    "dompdf/dompdf": "^3.0",
    "horstoeko/zugferd": "^1.0",
    "phpmailer/phpmailer": "^6.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "nextcloud/ocp": "^32.0 || ^33.0 || ^34.0",
    "doctrine/dbal": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "OCA\\Rechnungswerk\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OCA\\Rechnungswerk\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit -c tests/phpunit.xml",
    "test:unit": "phpunit -c tests/phpunit.xml"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2"
    }
  }
}
